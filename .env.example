# ===== Daniel — fill these in before deploying =====

# ClickUp personal API token (Settings → Apps → API Token)
CLICKUP_API_TOKEN=pk_XXXXXXXXXXXXXXXXXXXXXXX

# ClickUp Space ID where new client folders should be created
# (Open the space in browser, copy numeric ID from URL)
CLICKUP_SPACE_ID=

# Path to the template JSON describing the folder/lists/tasks to replicate.
# Default points to ./templates/client-template.json
CLICKUP_TEMPLATE_FILE=./templates/client-template.json

# Shared secret used to verify incoming webhook requests.
# Put the same value in your Typeform/Jotform/Tally webhook header `X-Webhook-Secret`.
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Which form vendor is sending the webhook? typeform | jotform | tally | generic
FORM_VENDOR=typeform

# Field identifier on the form that holds the new client's name.
# - Typeform: the question's `ref` (set this in the Typeform question Logic panel)
# - Jotform: the question label or qid
# - Tally: the question label
CLIENT_NAME_FIELD=client_name

# Port (Render/Railway set this automatically; only matters locally)
PORT=3000
